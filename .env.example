# Database
DATABASE_URL=postgresql://oekaki:password@localhost:5432/oekaki_db

# JWT
JWT_SECRET=your-secret-key-change-this-in-production

# Backend
PORT=3000

# アプリのベースURL（未設定時は localhost:5173 / ngrok 両対応）
# APP_URL=

# ngrok (make ngrok 用)
NGROK_AUTHTOKEN=

# google OAuth（以下を Google Cloud Console に登録）
# - http://localhost:3000/v1/auth/google/callback（localhost:5173 からログイン時）
# - https://xxx.ngrok-free.dev/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
